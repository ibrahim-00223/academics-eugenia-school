# ============================================================
# EUGENIA ACADEMICS — Environment Variables
# Copy this file to .env.local (dev) ou configurer dans Railway
# NEVER commit .env.local to git
# ============================================================

# ── SUPABASE ─────────────────────────────────────────────────
# Trouvé dans : Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── APP ──────────────────────────────────────────────────────
# En local : http://localhost:3000
# Sur Railway : https://your-app.up.railway.app (auto-généré)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AUTH — Restriction de domaine ────────────────────────────
# Domaines email autorisés (séparés par des virgules, sans espaces)
# Laisser vide pour tout autoriser (dev local uniquement)
ALLOWED_EMAIL_DOMAINS=yourdomain.fr

# ── APIFY (scraping LinkedIn) ─────────────────────────────────
# Créer un compte sur https://apify.com → Settings → Integrations
APIFY_API_TOKEN=your-apify-token-here
APIFY_WEBHOOK_SECRET=random-secret-for-webhook-verification

# ── ANTHROPIC (Claude AI) ────────────────────────────────────
# Créer une clé API sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── OPENAI (Whisper — transcription podcasts) ─────────────────
# Créer une clé API sur https://platform.openai.com
OPENAI_API_KEY=sk-your-openai-key-here

# ── CRON WORKER ──────────────────────────────────────────────
# Secret partagé entre le worker cron (workers/cron.ts)
# et les endpoints API (/api/scraping/cron, /api/ai/*)
# Générer avec : openssl rand -base64 32
CRON_SECRET=your-random-cron-secret-here

# ── RAILWAY (configuré automatiquement en prod) ──────────────
# PORT est injecté automatiquement par Railway
# PORT=3000
